# Public origins used when API responses build absolute URLs.
# Use https://www.step.parts and https://api.step.parts in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional Neon Postgres connection string for internal download ranking.
# Leave unset for local development if all download counts should behave as zero.
DATABASE_URL=

# Optional production STEP media overrides.
# By default production uses Vercel Git metadata and falls back to main.
# STEP_PARTS_GITHUB_REF=main
# STEP_PARTS_GITHUB_REPOSITORY=owner/repo
# STEP_PARTS_GITHUB_OWNER=owner
# STEP_PARTS_GITHUB_REPO=repo

# Optional: force checked-out STEP files instead of GitHub LFS media in a
# production-like local run.
# STEP_PARTS_STEP_ASSET_MODE=local
